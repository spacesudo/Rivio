# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Enoki API key (from Mysten Labs dashboard)
NEXT_PUBLIC_ENOKI_API_KEY=

# Google OAuth client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Apple OAuth client ID (optional)
NEXT_PUBLIC_APPLE_CLIENT_ID=

# Rivio backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sui network: mainnet | testnet | devnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Swap treasury wallet address (for commission routing)
NEXT_PUBLIC_SWAP_TREASURY_ADDRESS=

# Swap commission in basis points (100 = 1%)
NEXT_PUBLIC_SWAP_COMMISSION_BPS=85
